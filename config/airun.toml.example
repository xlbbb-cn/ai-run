# airun configuration file
# Copy to ~/.config/airun/config.toml and fill in your API keys.

[api]
# Which provider to use: "openai" or "anthropic"
provider = "openai"

# OpenAI settings
openai_api_key = "sk-..."
openai_model   = "gpt-4o"

# Anthropic settings
anthropic_api_key = "sk-ant-..."
anthropic_model   = "claude-opus-4-5"

# Optional: override the API base URL (e.g. for a proxy or local LLM)
# base_url = "https://api.openai.com/v1"

[behavior]
# Path to the blocklist file (supports ~ expansion)
blocklist_file = "~/.config/airun/blocklist.txt"

# Print the generated command before executing
show_command = true

# Ask for confirmation before executing the command
confirm_before_run = false
